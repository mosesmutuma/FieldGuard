{
  "version": 2,
  "builds": [
    {
      "src": "attendance/wsgi.py",
      "config": { "maxLambdaSize": "15mb" },
      "use": "@vercel/python"
    },
    {
      "src": "build_files.sh",
      "use": "@vercel/static-build",
      "config": { "distDir": "attendance/staticfiles" }
    }
  ],
  "routes": [
    {
      "src": "/static/(.*)",
      "dest": "/attendance/staticfiles/$1"
    },
    {
      "src": "/(.*)",
      "dest": "attendance/wsgi.py"
    }
  ]
}